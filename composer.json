{
    "name": "rdcstarr/docs-generator",
    "description": "Generate AI-optimized Markdown documentation from Laravel-ecosystem docs sites for Claude, Cursor, and Copilot.",
    "keywords": [
        "laravel",
        "docs",
        "ai",
        "claude",
        "cursor",
        "copilot",
        "documentation",
        "deepseek",
        "openai"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "rdcstarr",
            "email": "spacenetworkcloud@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/console": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/support": "^13.0",
        "laravel/ai": "0.x-dev"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Rdcstarr\\DocsGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rdcstarr\\DocsGenerator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rdcstarr\\DocsGenerator\\DocsGeneratorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
