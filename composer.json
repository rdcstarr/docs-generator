{
    "name": "rdcstarr/docs-generator",
    "description": "Generate AI-optimized Markdown documentation from Laravel-ecosystem docs sites for Claude, Cursor, and Copilot.",
    "keywords": [
        "laravel",
        "docs",
        "ai",
        "claude",
        "cursor",
        "copilot",
        "documentation",
        "deepseek",
        "openai"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "rdcstarr",
            "email": "spacenetworkcloud@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "deepseek-php/deepseek-php-client": "@dev",
        "openai-php/client": "^0.10",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "suggest": {
        "deepseek-php/deepseek-php-client": "Required for the DeepSeek AI provider",
        "openai-php/client": "Required for the OpenAI AI provider"
    },
    "autoload": {
        "psr-4": {
            "Rdcstarr\\DocsGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rdcstarr\\DocsGenerator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rdcstarr\\DocsGenerator\\DocsGeneratorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
